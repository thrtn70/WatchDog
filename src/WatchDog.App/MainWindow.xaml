<Window x:Class="WatchDog.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WatchDog.App.Converters"
        xmlns:controls="clr-namespace:WatchDog.App.Controls"
        xmlns:helpers="clr-namespace:WatchDog.App.Helpers"
        Title="WatchDog" Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource UIFont}" FontSize="13"
        Icon="pack://application:,,,/Resources/WatchDog.ico">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisConverter"/>
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}"/>

        <!-- Clip card style for grid view -->
        <Style x:Key="ClipCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Width" Value="210"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect" Value="{StaticResource CardHoverShadow}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Clip row style for list view -->
        <Style x:Key="ClipRow" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#08FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ═══ Command Bar (38px) ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>       <!-- Brand -->
                    <ColumnDefinition Width="12"/>         <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>       <!-- View toggles -->
                    <ColumnDefinition Width="8"/>           <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>       <!-- Separator -->
                    <ColumnDefinition Width="8"/>           <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>       <!-- Game filter -->
                    <ColumnDefinition Width="6"/>           <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>       <!-- Sort -->
                    <ColumnDefinition Width="*"/>           <!-- Center: status -->
                    <ColumnDefinition Width="Auto"/>       <!-- Settings -->
                    <ColumnDefinition Width="Auto"/>       <!-- Storage -->
                    <ColumnDefinition Width="Auto"/>       <!-- Refresh -->
                </Grid.ColumnDefinitions>

                <!-- Brand mark + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/WatchDog.png"
                           Width="18" Height="18" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="WatchDog" Style="{StaticResource BrandTitle}"/>
                </StackPanel>

                <!-- View mode toggles -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="GridViewToggle" Content="&#xF0E2;"
                                  Style="{StaticResource ToggleIconButton}"
                                  IsChecked="True" ToolTip="Grid view"
                                  AutomationProperties.Name="Grid view"
                                  Checked="OnGridViewChecked"/>
                    <ToggleButton x:Name="ListViewToggle" Content="&#xE8FD;"
                                  Style="{StaticResource ToggleIconButton}"
                                  ToolTip="List view"
                                  AutomationProperties.Name="List view"
                                  Checked="OnListViewChecked"/>
                </StackPanel>

                <!-- Vertical separator -->
                <Border Grid.Column="4" Width="1" Height="18" Background="{StaticResource Surface1Brush}"
                        VerticalAlignment="Center"/>

                <!-- Game filter -->
                <ComboBox Grid.Column="6" ItemsSource="{Binding GameNames}"
                          SelectedItem="{Binding FilterGame}" Width="160"
                          VerticalAlignment="Center" ToolTip="Filter by game"/>

                <!-- Sort mode -->
                <ComboBox Grid.Column="8"
                          ItemsSource="{Binding Source={x:Static helpers:EnumHelper.ClipSortModes}}"
                          SelectedItem="{Binding SortMode}" Width="100"
                          VerticalAlignment="Center" ToolTip="Sort clips"/>

                <!-- Center: capture status -->
                <StackPanel Grid.Column="9" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Recording dot (visible when recording) -->
                    <Ellipse x:Name="RecordingDot" Width="8" Height="8" Margin="0,0,8,0"
                             Fill="{StaticResource RecordingBrush}" Visibility="Collapsed"/>
                    <TextBlock Text="{Binding CaptureStatusText}"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource SubtextBrush}"/>
                </StackPanel>

                <!-- Settings gear -->
                <Button Grid.Column="10" Content="&#xE713;" FontSize="15"
                        Click="OnSettingsClick" ToolTip="Settings"
                        AutomationProperties.Name="Settings"
                        Style="{StaticResource IconButton}"
                        VerticalAlignment="Center"/>

                <!-- Storage -->
                <Button Grid.Column="11" Content="&#xE7F1;" FontSize="14"
                        Click="OnStorageDashboardClick" ToolTip="Storage dashboard"
                        AutomationProperties.Name="Storage dashboard"
                        Style="{StaticResource IconButton}"
                        VerticalAlignment="Center"/>

                <!-- Refresh -->
                <Button Grid.Column="12" Content="&#xE72C;" FontSize="13"
                        Command="{Binding RefreshClipsCommand}" ToolTip="Refresh clips"
                        AutomationProperties.Name="Refresh clips"
                        Style="{StaticResource IconButton}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ Content Area ═════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                <ColumnDefinition x:Name="EditorColumn" Width="340" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- ── Clip Library ──────────────────────────────────────────── -->

            <!-- Grid View -->
            <ListBox x:Name="ClipGridView" Grid.Column="0"
                     ItemsSource="{Binding Clips}"
                     SelectedItem="{Binding SelectedClip}"
                     Background="{StaticResource BaseBrush}" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     Padding="4">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ClipCard}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Play"
                                              Command="{Binding Data.PlayClipCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="Favorite"
                                              Command="{Binding Data.ToggleFavoriteCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="Open in Explorer"
                                              Command="{Binding Data.OpenInExplorerCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="Share to Discord"
                                              Command="{Binding Data.ShareToDiscordCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="Delete" Foreground="{StaticResource DangerBrush}"
                                              Command="{Binding Data.DeleteClipCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="118"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Thumbnail (hover-to-scrub) -->
                                <Grid Grid.Row="0" ClipToBounds="True">
                                    <Border Background="{StaticResource Surface1Brush}" CornerRadius="5,5,0,0">
                                        <controls:ScrubbableThumbnail
                                            StaticThumbnail="{Binding Thumbnail}"
                                            ClipFilePath="{Binding FilePath}"/>
                                    </Border>
                                    <!-- Duration badge -->
                                    <Border Background="#CC0A1114" CornerRadius="3" Padding="4,1"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5">
                                        <TextBlock Text="{Binding DurationDisplay}" FontSize="10"
                                                   FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                                    </Border>
                                    <!-- Favorite star -->
                                    <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{StaticResource WarningBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,3"
                                               Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}"/>
                                </Grid>

                                <!-- Info -->
                                <StackPanel Grid.Row="1" Margin="8,4,8,8">
                                    <TextBlock Text="{Binding GameName}" FontWeight="SemiBold" FontSize="11"
                                               Foreground="{StaticResource AccentBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding CreatedAtDisplay}" FontSize="11"
                                                   Foreground="{StaticResource SubtextBrush}"/>
                                        <TextBlock Text=" · " FontSize="11"
                                                   Foreground="{StaticResource OverlayBrush}"/>
                                        <TextBlock Text="{Binding FileSizeDisplay}" FontSize="11"
                                                   Foreground="{StaticResource SubtextBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- List View (hidden by default) -->
            <ListBox x:Name="ClipListView" Grid.Column="0"
                     ItemsSource="{Binding Clips}"
                     SelectedItem="{Binding SelectedClip}"
                     Background="{StaticResource BaseBrush}" BorderThickness="0"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     Visibility="Collapsed"
                     Padding="4">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ClipRow}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Play"
                                              Command="{Binding Data.PlayClipCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="Favorite"
                                              Command="{Binding Data.ToggleFavoriteCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="Open in Explorer"
                                              Command="{Binding Data.OpenInExplorerCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="Share to Discord"
                                              Command="{Binding Data.ShareToDiscordCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="Delete" Foreground="{StaticResource DangerBrush}"
                                              Command="{Binding Data.DeleteClipCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <!-- Small thumbnail -->
                                <Border Grid.Column="0" CornerRadius="3" ClipToBounds="True"
                                        Background="{StaticResource Surface1Brush}"
                                        Width="60" Height="34" Margin="0,0,8,0">
                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Name + game -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="Medium"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding GameName}" FontSize="11"
                                               Foreground="{StaticResource AccentBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Date -->
                                <TextBlock Grid.Column="2" Text="{Binding CreatedAtDisplay}"
                                           FontSize="11" Foreground="{StaticResource SubtextBrush}"
                                           VerticalAlignment="Center" Margin="12,0"/>

                                <!-- Duration -->
                                <TextBlock Grid.Column="3" Text="{Binding DurationDisplay}"
                                           FontSize="11" Foreground="{StaticResource SubtextBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                <!-- Size -->
                                <TextBlock Grid.Column="4" Text="{Binding FileSizeDisplay}"
                                           FontSize="11" Foreground="{StaticResource OverlayBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state (shown when no clips) -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsHitTestVisible="False">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Clips.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <!-- Dog skull icon using the app logo -->
                <Image Source="pack://application:,,,/Resources/WatchDog.png"
                       Width="48" Height="48" Opacity="0.2" Margin="0,0,0,16"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="No clips yet" FontSize="16" FontWeight="SemiBold"
                           FontFamily="{StaticResource DisplayFont}"
                           Foreground="{StaticResource SubtextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="Start a game and press F9 to save highlights"
                           FontSize="12" Foreground="{StaticResource OverlayBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5"
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

            <!-- ── Editor Panel ──────────────────────────────────────────── -->
            <Border Grid.Column="2" Background="{StaticResource MantleBrush}"
                    DataContext="{Binding ClipEditor}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Video player -->
                    <controls:VideoPlayerControl Grid.Row="0" Margin="6"
                        Source="{Binding Source}"
                        IsPlaying="{Binding IsPlaying, Mode=TwoWay}"
                        Position="{Binding Position, Mode=TwoWay}"/>

                    <!-- Empty editor state (overlays video player in Row 0 — player renders nothing when DataContext is null) -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.ClipEditor, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="{StaticResource Surface2Brush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Select a clip to preview"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource SubtextBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Click any clip from the library"
                                   FontSize="11" Foreground="{StaticResource OverlayBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Timeline -->
                    <controls:VideoTimeline Grid.Row="1" Margin="6,0"
                        Duration="{Binding Duration}"
                        Position="{Binding Position, Mode=TwoWay}"
                        TrimStart="{Binding TrimStart, Mode=TwoWay}"
                        TrimEnd="{Binding TrimEnd, Mode=TwoWay}"
                        ThumbnailFrames="{Binding ThumbnailFrames}"
                        Visibility="{Binding Source, Converter={StaticResource NullToVisConverter}}"/>

                    <!-- Details + controls -->
                    <Border Grid.Row="2" Padding="10,8"
                            Visibility="{Binding DataContext.SelectedClip, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NullToVisConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.SelectedClip.FileName, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <TextBlock Text="{Binding DataContext.SelectedClip.GameName, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="11" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text=" · " Foreground="{StaticResource OverlayBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding DataContext.SelectedClip.DurationDisplay, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                                <TextBlock Text=" · " Foreground="{StaticResource OverlayBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding DataContext.SelectedClip.FileSizeDisplay, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Trim" Margin="0,0,4,0"
                                        Command="{Binding StartTrimCommand}" Padding="12,4"/>
                                <Button Content="Open Folder" Margin="0,0,4,0" Padding="12,4"
                                        Command="{Binding DataContext.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding DataContext.SelectedClip, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Button Content="Share" Padding="12,4"
                                        Style="{StaticResource ActionButton}"
                                        Command="{Binding DataContext.ShareToDiscordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding DataContext.SelectedClip, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </StackPanel>

                            <!-- Trim panel -->
                            <Border Margin="0,8,0,0" Padding="8" Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="4"
                                    Visibility="{Binding IsTrimming, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="TRIM" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource SubtextBrush}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource OverlayBrush}"
                                               Text="Drag handles on the timeline, then export."/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="Export" Command="{Binding ExecuteTrimCommand}"
                                                Style="{StaticResource ActionButton}" Padding="12,5"
                                                Margin="0,0,4,0"/>
                                        <Button Content="Cancel" Command="{Binding CancelTrimCommand}"
                                                Padding="10,5"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TrimStatus}" Margin="0,4,0,0"
                                               Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Floating panels canvas (draggable, resizable overlays) -->
        <Canvas Grid.Row="1" ClipToBounds="True" x:Name="FloatingPanelCanvas"
                Loaded="FloatingPanelCanvas_Loaded">

            <controls:FloatingPanel x:Name="PerformancePanel"
                                     Title="Performance"
                                     PanelWidth="180" PanelHeight="150"
                                     MinPanelWidth="140" MinPanelHeight="100"
                                     PanelTop="8">
                <controls:PerformanceOverlay DataContext="{Binding Performance}"/>
            </controls:FloatingPanel>

            <controls:FloatingPanel x:Name="AudioPanel"
                                     Title="Audio"
                                     PanelWidth="280" PanelHeight="190"
                                     MinPanelWidth="200" MinPanelHeight="120">
                <controls:AudioMixerPanel DataContext="{Binding AudioMixer}"/>
            </controls:FloatingPanel>
        </Canvas>

        <!-- ═══ Status Strip (24px) ══════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource CrustBrush}"
                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,1,0,0">
            <Grid Margin="10,0">
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{StaticResource SubtextBrush}"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
