<Window x:Class="WatchDog.App.Controls.ClipSavedToast"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize">
    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
            BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
            Padding="12,10" Margin="8" MaxWidth="320">
        <Border.Effect>
            <StaticResource ResourceKey="FloatingPanelShadow"/>
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="&#x2714;" FontSize="14"
                           Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock Text="Clip Saved" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource SuccessBrush}"/>
            </StackPanel>
            <TextBlock x:Name="ClipNameText" FontSize="12"
                       Foreground="{StaticResource TextBrush}"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="ClipDetailsText" FontSize="11"
                       Foreground="{StaticResource SubtextBrush}" Margin="0,2,0,0"/>
        </StackPanel>
    </Border>
</Window>
