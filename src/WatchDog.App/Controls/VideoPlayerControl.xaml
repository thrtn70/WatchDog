<UserControl x:Class="WatchDog.App.Controls.VideoPlayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Video area -->
        <MediaElement x:Name="Player" Grid.Row="0" Stretch="Uniform"
                      LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      MediaOpened="OnMediaOpened" MediaEnded="OnMediaEnded"/>

        <!-- Transport controls -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PlayPauseBtn" Content="&#x25B6;" Width="28" Height="28"
                        Grid.Column="0" Click="OnPlayPauseClick" FontSize="12"/>

                <TextBlock x:Name="TimeDisplay" Grid.Column="1" VerticalAlignment="Center"
                           Margin="8,0" Foreground="{StaticResource SubtextBrush}" FontSize="11"
                           Text="0:00 / 0:00"/>

                <Slider x:Name="PositionSlider" Grid.Column="2" VerticalAlignment="Center"
                        Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.1"
                        Thumb.DragStarted="OnSliderDragStarted"
                        Thumb.DragCompleted="OnSliderDragCompleted"
                        ValueChanged="OnSliderValueChanged"/>

                <!-- Volume -->
                <Slider x:Name="VolumeSlider" Grid.Column="3" Width="60" VerticalAlignment="Center"
                        Minimum="0" Maximum="1" Value="0.8"
                        ValueChanged="OnVolumeChanged"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
