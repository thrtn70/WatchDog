<UserControl x:Class="WatchDog.App.Controls.FloatingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MouseMove="Header_MouseMove"
             MouseLeftButtonUp="Header_MouseLeftButtonUp">

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource Surface1Brush}"
            BorderThickness="1" CornerRadius="8"
            Effect="{StaticResource FloatingPanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Drag header -->
            <Border Grid.Row="0" Background="{StaticResource Surface2Brush}"
                    CornerRadius="8,8,0,0" Padding="10,6"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    Cursor="SizeAll">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding Title, ElementName=Root}"
                               Foreground="{StaticResource SubtextBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Click="CollapseToggle_Click"
                            Background="Transparent" BorderThickness="0"
                            Padding="4,0" Cursor="Hand"
                            ToolTip="Collapse / Expand"
                            AutomationProperties.Name="Collapse or expand panel">
                        <TextBlock x:Name="CollapseIcon"
                                   Text="&#x25BC;"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="9" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content area (collapsible) -->
            <Border Grid.Row="1" x:Name="ContentArea"
                    CornerRadius="0,0,8,8" Padding="0">
                <ContentPresenter Content="{Binding PanelContent, ElementName=Root}"/>
            </Border>

            <!-- Resize grip (bottom-right corner) -->
            <Thumb Grid.Row="1"
                   Width="12" Height="12"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Cursor="SizeNWSE" Opacity="0.4"
                   DragDelta="ResizeThumb_DragDelta"
                   x:Name="ResizeGrip">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Canvas Width="10" Height="10" Margin="0,0,2,2">
                            <Line X1="9" Y1="1" X2="1" Y2="9" Stroke="{StaticResource OverlayBrush}" StrokeThickness="1"/>
                            <Line X1="9" Y1="4" X2="4" Y2="9" Stroke="{StaticResource OverlayBrush}" StrokeThickness="1"/>
                            <Line X1="9" Y1="7" X2="7" Y2="9" Stroke="{StaticResource OverlayBrush}" StrokeThickness="1"/>
                        </Canvas>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</UserControl>
