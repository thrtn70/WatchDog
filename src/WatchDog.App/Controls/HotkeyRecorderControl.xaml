<UserControl x:Class="WatchDog.App.Controls.HotkeyRecorderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             IsTabStop="True">
    <Border x:Name="RecorderBorder"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource Surface1Brush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8,4"
            Cursor="Hand"
            MouseLeftButtonDown="OnBorderClick">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="DisplayTextBlock"
                       Text="{Binding DisplayText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Text=" — click to change"
                       FontSize="11"
                       Foreground="{StaticResource SubtextBrush}"
                       VerticalAlignment="Center"
                       x:Name="HintText"/>
        </StackPanel>
    </Border>
    <!-- Focus state (AccentBrush border) is managed by code-behind
         in EnterRecordingMode/ExitRecordingMode to avoid animating
         frozen shared theme brush instances. -->
</UserControl>
