<UserControl x:Class="WatchDog.App.Controls.HotkeyRecorderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             IsTabStop="True">
    <Border x:Name="RecorderBorder"
            Background="{StaticResource SurfaceBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8,4"
            Cursor="Hand"
            MouseLeftButtonDown="OnBorderClick">
        <!-- Local brush instance to avoid animating shared theme resources -->
        <Border.BorderBrush>
            <SolidColorBrush x:Name="BorderColor" Color="{StaticResource Surface1Color}"/>
        </Border.BorderBrush>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="DisplayTextBlock"
                       Text="{Binding DisplayText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Text=" — click to change"
                       FontSize="11"
                       Foreground="{StaticResource SubtextBrush}"
                       VerticalAlignment="Center"
                       x:Name="HintText"/>
        </StackPanel>
    </Border>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="GotKeyboardFocus">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetName="BorderColor"
                                    Storyboard.TargetProperty="Color"
                                    To="{StaticResource AccentColor}" Duration="0:0:0.15"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="LostKeyboardFocus">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetName="BorderColor"
                                    Storyboard.TargetProperty="Color"
                                    To="{StaticResource Surface1Color}" Duration="0:0:0.15"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
