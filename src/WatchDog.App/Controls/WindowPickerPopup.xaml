<Window x:Class="WatchDog.App.Controls.WindowPickerPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="360" Height="400"
        Background="Transparent"
        Deactivated="OnDeactivated">

    <Border Background="{StaticResource BaseBrush}"
            BorderBrush="{StaticResource Surface1Brush}"
            BorderThickness="1" CornerRadius="8"
            Padding="0"
            Effect="{StaticResource FloatingPanelShadow}">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="14,12">
                <DockPanel>
                    <TextBlock Text="Select Window to Capture"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="Refresh"
                            x:Name="RefreshButton"
                            HorizontalAlignment="Right"
                            Padding="10,4"
                            FontSize="11"
                            Foreground="{StaticResource SubtextBrush}"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource Surface1Brush}"
                            BorderThickness="1"
                            Cursor="Hand"/>
                </DockPanel>
            </Border>

            <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource Surface1Brush}"/>

            <!-- Window list -->
            <ListBox x:Name="WindowList"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="4"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,8" CornerRadius="4" Cursor="Hand"
                                Background="Transparent"
                                x:Name="ItemBorder">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontFamily="{StaticResource UIFont}"
                                           FontSize="13"
                                           Foreground="{StaticResource TextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="320"/>
                                <TextBlock Text="{Binding ExecutableName}"
                                           FontFamily="{StaticResource UIFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource SubtextBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"
                                        Value="{StaticResource Surface1Brush}"/>
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBd" Background="Transparent"
                                            CornerRadius="4" Margin="2,0">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background"
                                                    Value="{StaticResource Surface1Brush}"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background"
                                                    Value="{StaticResource Surface1Brush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
