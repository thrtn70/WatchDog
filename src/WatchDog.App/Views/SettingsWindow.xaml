<Window x:Class="WatchDog.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:WatchDog.App.Helpers"
        xmlns:controls="clr-namespace:WatchDog.App.Controls"
        xmlns:converters="clr-namespace:WatchDog.App.Converters"
        Title="WatchDog Settings" Height="600" Width="620"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource UIFont}" FontSize="13"
        Icon="pack://application:,,,/Resources/WatchDog.ico">

    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisConverter"/>
        <converters:EnumBoolConverter x:Key="EnumBoolConverter"/>

        <!-- Sidebar tab item style -->
        <Style x:Key="SettingsTab" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Background="Transparent"
                                Padding="{TemplateBinding Padding}" CornerRadius="4"
                                Margin="0,0,0,2">
                            <TextBlock Text="{TemplateBinding Header}"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SubtleHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" TabStripPlacement="Left" Background="Transparent"
                    BorderThickness="0" Padding="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Sidebar -->
                        <Border Grid.Column="0" Background="{StaticResource MantleBrush}"
                                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,0,1,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="8,12">
                                <TabPanel IsItemsHost="True"/>
                            </ScrollViewer>
                        </Border>
                        <!-- Content -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                                      Padding="20,16">
                            <ContentPresenter
                                Content="{TemplateBinding SelectedContent}"
                                ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                ContentStringFormat="{TemplateBinding SelectedContentStringFormat}"/>
                        </ScrollViewer>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <!-- ═══ Capture ═══════════════════════════════════════════════ -->
            <TabItem Header="Capture" Style="{StaticResource SettingsTab}">
                <StackPanel>
                    <TextBlock Text="Capture" Style="{StaticResource Heading2}" Margin="0,0,0,12"/>

                    <CheckBox Content="Always-on desktop capture (record even without a game)"
                              IsChecked="{Binding DesktopCaptureEnabled}" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Monitor:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding Monitors}"
                                  SelectedItem="{Binding SelectedMonitor}"
                                  DisplayMemberPath="DisplayName" Width="280"
                                  AutomationProperties.Name="Monitor selection"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Width:" VerticalAlignment="Center" Grid.Column="0" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding OutputWidth}" Grid.Column="1" PreviewTextInput="NumericOnly_PreviewTextInput"
                                 AutomationProperties.Name="Output width"/>
                        <TextBlock Text="Height:" VerticalAlignment="Center" Grid.Column="2" Margin="12,0,8,0"/>
                        <TextBox Text="{Binding OutputHeight}" Grid.Column="3" PreviewTextInput="NumericOnly_PreviewTextInput"
                                 AutomationProperties.Name="Output height"/>
                        <TextBlock Text="FPS:" VerticalAlignment="Center" Grid.Column="4" Margin="12,0,8,0"/>
                        <TextBox Text="{Binding Fps}" Grid.Column="5" PreviewTextInput="NumericOnly_PreviewTextInput"
                                 AutomationProperties.Name="Frames per second"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Encoder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding Source={x:Static helpers:EnumHelper.EncoderTypes}}"
                                  SelectedItem="{Binding Encoder}" Width="140"
                                  AutomationProperties.Name="Encoder type"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Quality (CQP):" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Constant quality parameter. Lower = better quality, larger files. Recommended: 18-23 for NVENC, 20-28 for x264."/>
                        <TextBox Text="{Binding Quality}" Width="48" PreviewTextInput="NumericOnly_PreviewTextInput"
                                 AutomationProperties.Name="Quality CQP value"/>
                        <TextBlock Text="Bitrate (kbps):" VerticalAlignment="Center" Margin="16,0,8,0" ToolTip="Target bitrate in kilobits per second. Higher = better quality, larger files. Recommended: 6000-20000 for 1080p."/>
                        <TextBox Text="{Binding Bitrate}" Width="64" PreviewTextInput="NumericOnly_PreviewTextInput"
                                 AutomationProperties.Name="Bitrate kilobits per second"/>
                    </StackPanel>

                    <!-- Recording Mode -->
                    <TextBlock Text="Recording Mode" FontWeight="SemiBold" Margin="0,8,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding Source={x:Static helpers:EnumHelper.RecordingModes}}"
                                  SelectedItem="{Binding RecordingMode}" Width="180"
                                  AutomationProperties.Name="Recording mode"/>
                    </StackPanel>
                    <TextBlock Text="ReplayBufferOnly: instant clips via hotkey. SessionRecording: full match files. Both: runs both."
                               TextWrapping="Wrap" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,8" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Segment Duration (min):" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Split session recordings into chunks of this length. Prevents single massive files. 0 = no splitting."/>
                        <TextBox Text="{Binding SegmentDurationMinutes}" Width="48" PreviewTextInput="NumericOnly_PreviewTextInput"
                                 AutomationProperties.Name="Segment duration minutes"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Max Duration (min, 0=unlimited):" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Auto-stop recording after this many minutes. 0 = record until the game exits."/>
                        <TextBox Text="{Binding MaxDurationMinutes}" Width="48" PreviewTextInput="NumericOnly_PreviewTextInput"
                                 AutomationProperties.Name="Max duration minutes"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- ═══ Audio ═════════════════════════════════════════════════ -->
            <TabItem Header="Audio" Style="{StaticResource SettingsTab}">
                <StackPanel>
                    <TextBlock Text="Audio" Style="{StaticResource Heading2}" Margin="0,0,0,12"/>

                    <CheckBox Content="Desktop audio" IsChecked="{Binding DesktopAudioEnabled}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Output Device:" VerticalAlignment="Center" Margin="0,0,8,0" Width="96"/>
                        <ComboBox ItemsSource="{Binding DesktopDevices}"
                                  SelectedItem="{Binding SelectedDesktopDevice}"
                                  DisplayMemberPath="DisplayName" Width="248"
                                  AutomationProperties.Name="Desktop audio output device"/>
                        <Button Content="&#x21BB;" Command="{Binding RefreshAudioDevicesCommand}"
                                Margin="4,0,0,0" ToolTip="Refresh devices" Padding="8,4" FontSize="14"
                                AutomationProperties.Name="Refresh audio devices"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Desktop Volume:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Minimum="0" Maximum="1" Value="{Binding DesktopAudioVolume}" Width="148"
                                VerticalAlignment="Center" TickFrequency="0.1" IsSnapToTickEnabled="False"
                                AutomationProperties.Name="Desktop audio volume"/>
                    </StackPanel>

                    <CheckBox Content="Microphone" IsChecked="{Binding MicAudioEnabled}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Input Device:" VerticalAlignment="Center" Margin="0,0,8,0" Width="96"/>
                        <ComboBox ItemsSource="{Binding MicDevices}"
                                  SelectedItem="{Binding SelectedMicDevice}"
                                  DisplayMemberPath="DisplayName" Width="248"
                                  AutomationProperties.Name="Microphone input device"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Mic Volume:" VerticalAlignment="Center" Margin="0,0,8,0" Width="96"/>
                        <Slider Minimum="0" Maximum="1" Value="{Binding MicAudioVolume}" Width="148"
                                VerticalAlignment="Center" TickFrequency="0.1" IsSnapToTickEnabled="False"
                                AutomationProperties.Name="Microphone volume"/>
                    </StackPanel>

                    <CheckBox Content="Separate audio tracks (mic on track 2)" IsChecked="{Binding SeparateAudioTracks}"/>
                </StackPanel>
            </TabItem>

            <!-- ═══ Storage ═══════════════════════════════════════════════ -->
            <TabItem Header="Storage" Style="{StaticResource SettingsTab}">
                <StackPanel>
                    <TextBlock Text="Storage" Style="{StaticResource Heading2}" Margin="0,0,0,12"/>

                    <!-- Replay Buffer -->
                    <TextBlock Text="Replay Buffer" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Buffer Duration (seconds):" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="How many seconds of gameplay to keep in memory. When you press the hotkey, the last N seconds are saved as a clip."/>
                        <TextBox Text="{Binding BufferSeconds}" Width="56"
                                 AutomationProperties.Name="Buffer duration seconds"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Max Buffer Size (MB):" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Maximum memory used by the replay buffer. Higher = longer buffer at higher quality settings."/>
                        <TextBox Text="{Binding BufferMaxSizeMb}" Width="56"
                                 AutomationProperties.Name="Max buffer size MB"/>
                    </StackPanel>

                    <!-- File Storage -->
                    <TextBlock Text="File Storage" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Save Path:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding SavePath}" Width="248"
                                 AutomationProperties.Name="Clip save path"/>
                        <Button Content="Browse" Command="{Binding BrowseSavePathCommand}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Max Storage (GB):" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="When total clips exceed this size, the oldest non-favorited clips are automatically deleted."/>
                        <TextBox Text="{Binding MaxStorageGb}" Width="48"
                                 AutomationProperties.Name="Max storage GB"/>
                        <TextBlock Text="Auto-delete after (days):" VerticalAlignment="Center" Margin="16,0,8,0" ToolTip="Clips older than this many days are automatically deleted (favorited clips are kept). 0 = never auto-delete by age."/>
                        <TextBox Text="{Binding AutoDeleteDays}" Width="48"
                                 AutomationProperties.Name="Auto-delete after days"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- ═══ Highlights ════════════════════════════════════════════ -->
            <TabItem Header="Highlights" Style="{StaticResource SettingsTab}">
                <StackPanel>
                    <TextBlock Text="Highlight Detection" Style="{StaticResource Heading2}" Margin="0,0,0,12"/>

                    <TextBlock Text="Set Recording Mode to 'Highlights' to enable auto-clipping on game events (kills, deaths, wins)."
                               TextWrapping="Wrap" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,12" FontSize="11"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Post-event delay (seconds):" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Wait this many seconds after a highlight event before saving the clip. Captures the aftermath (kill feed, scoreboard)."/>
                        <TextBox Text="{Binding HighlightDelaySeconds}" Width="48"
                                 AutomationProperties.Name="Post-event delay seconds"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Cooldown between clips (seconds):" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Minimum time between auto-saved highlight clips. Prevents spam during rapid multi-kills."/>
                        <TextBox Text="{Binding HighlightCooldownSeconds}" Width="48"
                                 AutomationProperties.Name="Cooldown between clips seconds"/>
                    </StackPanel>

                    <TextBlock Text="CS2: requires gamestate_integration_watchdog.cfg in your CS2 cfg folder."
                               TextWrapping="Wrap" Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                </StackPanel>
            </TabItem>

            <!-- ═══ Hotkeys ═══════════════════════════════════════════════ -->
            <TabItem Header="Hotkeys" Style="{StaticResource SettingsTab}">
                <StackPanel>
                    <TextBlock Text="Hotkeys" Style="{StaticResource Heading2}" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Save Clip:" VerticalAlignment="Center" Width="120"/>
                        <controls:HotkeyRecorderControl VirtualKey="{Binding SaveClipKey, Mode=TwoWay}"
                                                         Modifiers="{Binding SaveClipModifiers, Mode=TwoWay}"
                                                         MinWidth="120"
                                                         AutomationProperties.Name="Save clip hotkey"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Toggle Recording:" VerticalAlignment="Center" Width="120"/>
                        <controls:HotkeyRecorderControl VirtualKey="{Binding ToggleRecordingKey, Mode=TwoWay}"
                                                         Modifiers="{Binding ToggleRecordingModifiers, Mode=TwoWay}"
                                                         MinWidth="120"
                                                         AutomationProperties.Name="Toggle recording hotkey"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- ═══ Discord ═══════════════════════════════════════════════ -->
            <TabItem Header="Discord" Style="{StaticResource SettingsTab}">
                <StackPanel>
                    <TextBlock Text="Discord" Style="{StaticResource Heading2}" Margin="0,0,0,12"/>

                    <TextBlock Text="Share clips to a Discord channel via webhook. No bot or OAuth needed."
                               TextWrapping="Wrap" Foreground="{StaticResource SubtextBrush}" FontSize="11"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Webhook URL:" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding DiscordWebhookUrl}" Margin="0,0,0,12"
                             AutomationProperties.Name="Discord webhook URL"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="Bot Username:" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DiscordUsername}"
                                     AutomationProperties.Name="Bot username"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock Text="Message Template:" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DiscordMessageTemplate}"
                                     AutomationProperties.Name="Message template"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Tokens: {GameName}, {HighlightType}, {Duration}, {FileName}"
                               Foreground="{StaticResource SubtextBrush}" FontSize="10" Margin="0,0,0,8"/>
                    <CheckBox Content="Include metadata embed in message"
                              IsChecked="{Binding DiscordIncludeEmbed}"/>
                </StackPanel>
            </TabItem>

            <!-- ═══ General ═══════════════════════════════════════════════ -->
            <TabItem Header="General" Style="{StaticResource SettingsTab}">
                <StackPanel>
                    <TextBlock Text="General" Style="{StaticResource Heading2}" Margin="0,0,0,12"/>

                    <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" Margin="0,0,0,8"/>
                    <CheckBox Content="Start minimized to tray" IsChecked="{Binding StartMinimized}"/>

                    <!-- About / Version -->
                    <TextBlock Text="About" FontWeight="SemiBold" Margin="0,24,0,8"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,8">
                        <Run Text="WatchDog"/>
                        <Run Text="{Binding AppVersion, Mode=OneTime}"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Check for Updates"
                                Command="{Binding CheckForUpdateCommand}"
                                Padding="12,6"/>
                        <TextBlock Text="{Binding UpdateStatusText}" VerticalAlignment="Center"
                                   Margin="12,0,0,0" FontSize="11"
                                   Foreground="{StaticResource SubtextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Game Profiles Tab -->
            <TabItem Header="Game Profiles" Style="{StaticResource SettingsTab}">
                <Grid Margin="16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Game list with search -->
                    <DockPanel Grid.Column="0">
                        <TextBox DockPanel.Dock="Top"
                                 Text="{Binding GameProfiles.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12" Margin="0,0,8,8"
                                 Padding="6,4"
                                 Background="{StaticResource SurfaceBrush}"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource Surface1Brush}"
                                 AutomationProperties.Name="Search games">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Tag" Value="Search games..."/>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <ListBox ItemsSource="{Binding GameProfiles.FilteredGames}"
                                 SelectedItem="{Binding GameProfiles.SelectedGame}"
                                 Background="Transparent" BorderThickness="0"
                                 Margin="0,0,8,0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 AutomationProperties.Name="Game list">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,3">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock FontSize="10"
                                                   Foreground="{StaticResource SubtextBrush}">
                                            <Run Text="{Binding GenreDisplay, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding StatusDisplay, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Right: Profile editor -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,0,0,0"
                                    DataContext="{Binding GameProfiles}"
                                    Visibility="{Binding SelectedGame, Converter={StaticResource NullToVisConverter}}">

                            <TextBlock Text="{Binding SelectedGame.DisplayName}"
                                       Style="{StaticResource Heading2}" Margin="0,0,0,4"/>
                            <TextBlock FontSize="11" Foreground="{StaticResource SubtextBrush}"
                                       Margin="0,0,0,12">
                                <Run Text="{Binding SelectedGame.GenreDisplay, Mode=OneWay}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding SelectedGame.ExecutableName, Mode=OneWay}"/>
                            </TextBlock>

                            <!-- Recording Mode -->
                            <TextBlock Text="Recording Mode" FontWeight="SemiBold"
                                       FontSize="12" Margin="0,0,0,6"/>
                            <StackPanel Margin="0,0,0,16">
                                <RadioButton Content="Highlight (auto-clip on events)"
                                             IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Highlight}"
                                             IsEnabled="{Binding SelectedGame.SupportsHighlights}"
                                             Foreground="{StaticResource TextBrush}"
                                             FontSize="12" Margin="0,2"/>
                                <RadioButton Content="Session Recording (full capture)"
                                             IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=SessionRecording}"
                                             Foreground="{StaticResource TextBrush}"
                                             FontSize="12" Margin="0,2"/>
                                <RadioButton Content="Replay Buffer (hotkey to save)"
                                             IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=ReplayBuffer}"
                                             Foreground="{StaticResource TextBrush}"
                                             FontSize="12" Margin="0,2"/>
                            </StackPanel>

                            <!-- Highlight Sensitivity -->
                            <TextBlock Text="Highlight Sensitivity" FontWeight="SemiBold"
                                       FontSize="12" Margin="0,0,0,4"/>
                            <DockPanel Margin="0,0,0,16">
                                <TextBlock DockPanel.Dock="Left" Text="More clips"
                                           FontSize="10" Foreground="{StaticResource SubtextBrush}"
                                           VerticalAlignment="Center" Width="60"/>
                                <TextBlock DockPanel.Dock="Right" Text="Fewer clips"
                                           FontSize="10" Foreground="{StaticResource SubtextBrush}"
                                           VerticalAlignment="Center" Width="60"
                                           TextAlignment="Right"/>
                                <Slider Minimum="0.1" Maximum="1.0"
                                        Value="{Binding HighlightSensitivity}"
                                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"
                                        AutomationProperties.Name="Highlight sensitivity"/>
                            </DockPanel>

                            <!-- Actions -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Save Profile"
                                        Command="{Binding SaveProfileCommand}"
                                        Style="{StaticResource ActionButton}"
                                        Margin="0,0,8,0"/>
                                <Button Content="Reset to Default"
                                        Command="{Binding ResetProfileCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom bar: Save / Reset / Status -->
        <Border Grid.Row="1" Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="{StaticResource SuccessBrush}" FontStyle="Italic"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Reset Defaults" Command="{Binding ResetCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Save" Command="{Binding SaveCommand}"
                            Style="{StaticResource ActionButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
