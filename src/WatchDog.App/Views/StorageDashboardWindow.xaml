<Window x:Class="WatchDog.App.Views.StorageDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WatchDog.App.Converters"
        Title="Storage Dashboard" Height="450" Width="550"
        MinWidth="400" MinHeight="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource UIFont}" FontSize="13"
        Icon="pack://application:,,,/Resources/WatchDog.ico">

    <Window.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConv"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Summary -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,12"
                Effect="{StaticResource FloatingPanelShadow}">
            <StackPanel>
                <TextBlock Text="Storage Overview" Style="{StaticResource Heading1}" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Total Clips" Style="{StaticResource Caption}"/>
                        <TextBlock Text="{Binding TotalClips}" Style="{StaticResource StatNumber}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Used" Style="{StaticResource Caption}"/>
                        <TextBlock Text="{Binding UsedDisplay}" Style="{StaticResource StatNumber}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Remaining" Style="{StaticResource Caption}"/>
                        <TextBlock Text="{Binding RemainingDisplay}" Style="{StaticResource StatNumber}"
                                   Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Usage bar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <ProgressBar Value="{Binding UsagePercent}" Maximum="100" Height="24"
                         AutomationProperties.Name="Storage usage"/>
            <TextBlock Text="{Binding UsagePercentDisplay}" HorizontalAlignment="Center"
                       VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
        </Grid>

        <!-- Per-game breakdown -->
        <ListView Grid.Row="2" ItemsSource="{Binding GameUsages}"
                  Background="{StaticResource BaseBrush}" BorderThickness="0"
                  AutomationProperties.Name="Storage breakdown by game">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Game" Width="180"
                                    DisplayMemberBinding="{Binding GameName}"/>
                    <GridViewColumn Header="Clips" Width="60"
                                    DisplayMemberBinding="{Binding ClipCount}"/>
                    <GridViewColumn Header="Size" Width="90"
                                    DisplayMemberBinding="{Binding TotalBytes, Converter={StaticResource FileSizeConv}}"/>
                    <GridViewColumn Header="Size (GB)" Width="80"
                                    DisplayMemberBinding="{Binding TotalGb, StringFormat='{}{0:F2}'}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="0,0,8,0"/>
            <Button Content="Close" Click="OnCloseClick"/>
        </StackPanel>
    </Grid>
</Window>
