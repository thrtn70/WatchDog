<Window x:Class="WatchDog.App.Views.StatusOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WatchDog.App.Converters"
        Title="WatchDog Status"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="{StaticResource BaseBrush}"
            BorderBrush="{StaticResource Surface1Brush}"
            BorderThickness="1"
            CornerRadius="6"
            Opacity="0.9"
            Padding="8,4">
        <StackPanel Orientation="Horizontal">
            <!-- Status indicator dot with pulse animation when recording -->
            <Ellipse x:Name="StatusDot" Width="10" Height="10"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="{Binding IndicatorBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="PulseAnim">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.4" Duration="0:0:1"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="PulseAnim"/>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>

            <!-- Compact mode: status text only -->
            <TextBlock Text="{Binding StatusLine}"
                       FontFamily="{StaticResource UIFont}"
                       FontSize="11"
                       FontWeight="Medium"
                       Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsCompactMode, Converter={StaticResource BoolToVis}}"/>

            <!-- Expanded mode: game name + clip count + status -->
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsExpandedMode, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding GameName}"
                           FontFamily="{StaticResource DisplayFont}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" · " Foreground="{StaticResource SubtextBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ClipCountText}"
                           FontFamily="{StaticResource UIFont}"
                           FontSize="11"
                           Foreground="{StaticResource SubtextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" · " Foreground="{StaticResource SubtextBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusLabel}"
                           FontFamily="{StaticResource UIFont}"
                           FontSize="11" FontWeight="Medium"
                           Foreground="{Binding StatusLabelBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
