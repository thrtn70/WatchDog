<UserControl x:Class="TikrClipr.App.Controls.HotkeyRecorderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             IsTabStop="True">
    <Border x:Name="RecorderBorder"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource Surface1Brush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8,4"
            Cursor="Hand"
            MouseLeftButtonDown="OnBorderClick">
        <TextBlock x:Name="DisplayTextBlock"
                   Text="{Binding DisplayText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AccentBrush}"
                   VerticalAlignment="Center"/>
    </Border>
</UserControl>
