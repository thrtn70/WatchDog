<UserControl x:Class="TikrClipr.App.Controls.PerformanceOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="8">
        <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="FPS:" FontSize="11"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FpsDisplay}" FontSize="11"
                           Foreground="{StaticResource GreenBrush}" FontWeight="SemiBold"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Dropped:" FontSize="11"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DroppedDisplay}" FontSize="11"
                           Foreground="{StaticResource TextBrush}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU:" FontSize="11"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CpuDisplay}" FontSize="11"
                           Foreground="{StaticResource TextBrush}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="RAM:" FontSize="11"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RamDisplay}" FontSize="11"
                           Foreground="{StaticResource TextBrush}"/>
            </Grid>
    </StackPanel>
</UserControl>
