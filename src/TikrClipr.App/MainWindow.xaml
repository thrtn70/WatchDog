<Window x:Class="TikrClipr.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:TikrClipr.App.Converters"
        xmlns:controls="clr-namespace:TikrClipr.App.Controls"
        xmlns:helpers="clr-namespace:TikrClipr.App.Helpers"
        Title="TikrClipr" Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI" FontSize="13"
        Icon="pack://application:,,,/Resources/TikrClipr.ico">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisConverter"/>
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}"/>

        <Style x:Key="ClipCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect" Value="{StaticResource CardHoverShadow}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Surface2Brush}"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource MantleBrush}" Padding="16,10"
                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="TikrClipr" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <ComboBox Grid.Column="1" ItemsSource="{Binding GameNames}"
                          SelectedItem="{Binding FilterGame}" Width="180"
                          HorizontalAlignment="Left" VerticalAlignment="Center"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding Source={x:Static helpers:EnumHelper.ClipSortModes}}"
                          SelectedItem="{Binding SortMode}" Width="110"
                          HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0"/>

                <TextBlock Grid.Column="3" Text="{Binding CaptureStatusText}"
                           VerticalAlignment="Center" Margin="12,0"
                           Foreground="{StaticResource GreenBrush}" FontWeight="SemiBold" FontSize="14"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="Storage" Click="OnStorageDashboardClick"
                            VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button Content="Refresh" Command="{Binding RefreshClipsCommand}"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Clip grid -->
            <ListBox Grid.Column="0" ItemsSource="{Binding Clips}"
                     SelectedItem="{Binding SelectedClip}"
                     Background="{StaticResource BaseBrush}" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ClipCard}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Play"
                                              Command="{Binding Data.PlayClipCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="Favorite"
                                              Command="{Binding Data.ToggleFavoriteCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="Open in Explorer"
                                              Command="{Binding Data.OpenInExplorerCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="Share to Discord"
                                              Command="{Binding Data.ShareToDiscordCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="Delete" Foreground="{StaticResource RedBrush}"
                                              Command="{Binding Data.DeleteClipCommand, Source={StaticResource Proxy}}"
                                              CommandParameter="{Binding}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="124"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Thumbnail -->
                                <Grid Grid.Row="0" ClipToBounds="True">
                                    <Border Background="{StaticResource Surface1Brush}" CornerRadius="8,8,0,0">
                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <!-- Duration badge -->
                                    <Border Background="#CC000000" CornerRadius="4" Padding="4,2"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="6">
                                        <TextBlock Text="{Binding DurationDisplay}" FontSize="11"
                                                   Foreground="White"/>
                                    </Border>
                                    <!-- Favorite star -->
                                    <TextBlock Text="★" FontSize="16" Foreground="{StaticResource YellowBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,4"
                                               Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}"/>
                                </Grid>

                                <!-- Info -->
                                <StackPanel Grid.Row="1" Margin="8,6,8,8">
                                    <TextBlock Text="{Binding GameName}" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource AccentBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding CreatedAtDisplay}" FontSize="11"
                                                   Foreground="{StaticResource SubtextBrush}"/>
                                        <TextBlock Text=" · " FontSize="11"
                                                   Foreground="{StaticResource SubtextBrush}"/>
                                        <TextBlock Text="{Binding FileSizeDisplay}" FontSize="11"
                                                   Foreground="{StaticResource SubtextBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="2" Background="{StaticResource Surface1Brush}"
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

            <!-- Preview / Editor panel -->
            <Border Grid.Column="2" Background="{StaticResource MantleBrush}"
                    DataContext="{Binding ClipEditor}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Video player -->
                    <controls:VideoPlayerControl Grid.Row="0" Margin="8"
                        Source="{Binding Source}"
                        IsPlaying="{Binding IsPlaying, Mode=TwoWay}"
                        Position="{Binding Position, Mode=TwoWay}"/>

                    <!-- Empty state (shown when no clip is selected) -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.ClipEditor, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <!-- Segoe MDL2 Assets video glyph -->
                        <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                   Foreground="{StaticResource Surface2Brush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="No clip selected" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource SubtextBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Choose a clip from the grid to preview and edit"
                                   FontSize="12" Foreground="{StaticResource OverlayBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>

                    <!-- Timeline -->
                    <controls:VideoTimeline Grid.Row="1" Margin="8,0"
                        Duration="{Binding Duration}"
                        Position="{Binding Position, Mode=TwoWay}"
                        TrimStart="{Binding TrimStart, Mode=TwoWay}"
                        TrimEnd="{Binding TrimEnd, Mode=TwoWay}"
                        ThumbnailFrames="{Binding ThumbnailFrames}"
                        Visibility="{Binding Source, Converter={StaticResource NullToVisConverter}}"/>

                    <!-- Details + controls -->
                    <Border Grid.Row="2" Padding="12"
                            Visibility="{Binding DataContext.SelectedClip, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NullToVisConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.SelectedClip.FileName, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding DataContext.SelectedClip.GameName, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="12" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text=" · " Foreground="{StaticResource SubtextBrush}"/>
                                <TextBlock Text="{Binding DataContext.SelectedClip.DurationDisplay, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="12" Foreground="{StaticResource SubtextBrush}"/>
                                <TextBlock Text=" · " Foreground="{StaticResource SubtextBrush}"/>
                                <TextBlock Text="{Binding DataContext.SelectedClip.FileSizeDisplay, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="12" Foreground="{StaticResource SubtextBrush}"/>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Trim" Margin="0,0,4,0"
                                        Command="{Binding StartTrimCommand}"/>
                                <Button Content="Open Folder" Margin="0,0,4,0"
                                        Command="{Binding DataContext.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding DataContext.SelectedClip, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Button Content="Share" Margin="0,0,4,0"
                                        Command="{Binding DataContext.ShareToDiscordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding DataContext.SelectedClip, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </StackPanel>

                            <!-- Trim panel -->
                            <Border Margin="0,8,0,0" Padding="8" Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="6"
                                    Visibility="{Binding IsTrimming, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="Trim Clip" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBlock FontSize="12" Foreground="{StaticResource SubtextBrush}">
                                        <Run Text="Drag the handles on the timeline above, or trim will use current positions."/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="Export Trim" Command="{Binding ExecuteTrimCommand}"
                                                Style="{StaticResource ActionButton}" Margin="0,0,4,0"/>
                                        <Button Content="Cancel" Command="{Binding CancelTrimCommand}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TrimStatus}" Margin="0,4,0,0"
                                               Foreground="{StaticResource GreenBrush}" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Floating panels canvas (draggable, resizable overlays) -->
        <Canvas Grid.Row="1" ClipToBounds="True" x:Name="FloatingPanelCanvas"
                Loaded="FloatingPanelCanvas_Loaded">

            <controls:FloatingPanel x:Name="PerformancePanel"
                                     Title="Performance"
                                     PanelWidth="180" PanelHeight="150"
                                     MinPanelWidth="140" MinPanelHeight="100"
                                     PanelTop="8">
                <controls:PerformanceOverlay DataContext="{Binding Performance}"/>
            </controls:FloatingPanel>

            <controls:FloatingPanel x:Name="AudioPanel"
                                     Title="Audio"
                                     PanelWidth="280" PanelHeight="190"
                                     MinPanelWidth="200" MinPanelHeight="120">
                <controls:AudioMixerPanel DataContext="{Binding AudioMixer}"/>
            </controls:FloatingPanel>
        </Canvas>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource CrustBrush}" Padding="12,6"
                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{StaticResource SubtextBrush}" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding CaptureStatusText}" FontSize="11"
                           Foreground="{StaticResource GreenBrush}" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
