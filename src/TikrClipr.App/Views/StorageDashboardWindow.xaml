<Window x:Class="TikrClipr.App.Views.StorageDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:TikrClipr.App.Converters"
        Title="Storage Dashboard" Height="450" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BaseBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI" FontSize="13"
        Icon="pack://application:,,,/Resources/TikrClipr.ico">

    <Window.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConv"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Summary -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Storage Overview" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Total Clips" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                    <TextBlock Text="{Binding TotalClips}" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Used" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                    <TextBlock Text="{Binding UsedDisplay}" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Remaining" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                    <TextBlock Text="{Binding RemainingDisplay}" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource GreenBrush}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Usage bar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <ProgressBar Value="{Binding UsagePercent}" Maximum="100" Height="20"
                         Background="{StaticResource SurfaceBrush}"
                         Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Text="{Binding UsagePercentDisplay}" HorizontalAlignment="Center"
                       VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
        </Grid>

        <!-- Per-game breakdown -->
        <ListView Grid.Row="2" ItemsSource="{Binding GameUsages}"
                  Background="{StaticResource BaseBrush}" BorderThickness="0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Game" Width="180"
                                    DisplayMemberBinding="{Binding GameName}"/>
                    <GridViewColumn Header="Clips" Width="60"
                                    DisplayMemberBinding="{Binding ClipCount}"/>
                    <GridViewColumn Header="Size" Width="90"
                                    DisplayMemberBinding="{Binding TotalBytes, Converter={StaticResource FileSizeConv}}"/>
                    <GridViewColumn Header="Size (GB)" Width="80"
                                    DisplayMemberBinding="{Binding TotalGb, StringFormat='{}{0:F2}'}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="0,0,8,0"/>
            <Button Content="Close" Click="OnCloseClick"/>
        </StackPanel>
    </Grid>
</Window>
